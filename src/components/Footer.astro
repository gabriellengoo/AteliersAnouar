---
import { strings } from "../i18n/strings";
import logoWhite from "../../public/images/logo-white.png";
const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <a href={link("/")} class="footer-logo" aria-label="Ateliers Anouar — home">
      <img src={logoWhite.src} alt="Ateliers Anouar" />
    </a>

    <div class="footer-newsletter">
      <p class="footer-heading">{t.footer.newsletterTitle}</p>
      <form class="newsletter-form" method="post" action="#">
        <label for="footer-email" class="sr-only">Email</label>
        <input id="footer-email" type="email" name="email" placeholder={t.footer.newsletterPlaceholder} required />
        <button type="submit" class="newsletter-cta">{t.footer.newsletterCta}</button>
      </form>
    </div>

    <ul class="footer-links">
      {t.footer.links.map((label) => <li><a href="#">{label}</a></li>)}
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-cream);
    padding-block: var(--space-7);
    margin-top: auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: var(--space-7);
    align-items: start;
  }
  .footer-logo img {
    width: 64px;
    height: auto;
    filter: invert(0);
  }
  .footer-heading {
    font-weight: 700;
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }
  .newsletter-form {
    display: flex;
    align-items: stretch;
    max-width: 320px;
    border: 1px solid var(--color-cream);
    background: transparent;
  }
  .newsletter-form input {
    flex: 1;
    padding: var(--space-3) var(--space-3);
    border: 0;
    background: transparent;
    color: var(--color-cream);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
  }
  .newsletter-form input::placeholder {
    color: rgba(250, 249, 246, 0.6);
    font-style: italic;
  }
  .newsletter-cta {
    background: var(--color-cream);
    color: var(--color-ink);
    padding-inline: var(--space-4);
    font-weight: 700;
    font-size: var(--fs-small);
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-weight: 700;
    font-size: var(--fs-small);
    letter-spacing: var(--letter-wide);
    text-align: right;
  }
  .footer-links a:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .footer-links { text-align: left; }
  }
</style>
