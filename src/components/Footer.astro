---
import { strings } from "../i18n/strings";
import logoWhite from "../../public/images/logo-white.png";
const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <a href={link("/")} class="footer-logo" aria-label="Ateliers Anouar — home">
      <img src={logoWhite.src} alt="Ateliers Anouar" />
    </a>

    <div class="footer-newsletter">
      <p class="footer-heading">{t.footer.newsletterTitle}</p>
      <form class="newsletter-form" method="post" action="#">
        <label for="footer-email" class="sr-only">Email</label>
        <input id="footer-email" type="email" name="email" placeholder={t.footer.newsletterPlaceholder} required />
        <button type="submit" class="newsletter-cta">{t.footer.newsletterCta}</button>
      </form>
    </div>

    <ul class="footer-links">
      {t.footer.links.map((label) => <li><a href="#">{label}</a></li>)}
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-cream);
    padding-block: 1.75rem;
    margin-top: auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 72px 1fr minmax(150px, 190px);
    gap: 1.75rem;
    align-items: center;
  }
  .footer-logo img {
    width: 48px;
    height: auto;
    filter: invert(0);
  }
  .footer-heading {
    font-weight: 700;
    font-size: 0.7rem;
    margin-bottom: 0.45rem;
  }
  .newsletter-form {
    display: flex;
    align-items: stretch;
    max-width: 280px;
    border: 1px solid var(--color-cream);
    background: transparent;
  }
  .newsletter-form input {
    flex: 1;
    padding: 0.45rem 0.6rem;
    border: 0;
    background: transparent;
    color: var(--color-cream);
    font-family: var(--font-serif);
    font-size: 0.68rem;
  }
  .newsletter-form input::placeholder {
    color: rgba(250, 249, 246, 0.6);
    font-style: italic;
  }
  .newsletter-cta {
    background: var(--color-cream);
    color: var(--color-ink);
    padding-inline: 0.75rem;
    font-weight: 700;
    font-size: 0.68rem;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: var(--letter-wide);
    text-align: left;
  }
  .footer-links a:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .site-footer {
      padding: 1.1rem 6px 1.35rem;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0;
    }
    .footer-logo img { width: 45px; }
    .footer-heading {
      font-size: 0.58rem;
      margin-bottom: 0.35rem;
    }
    .newsletter-form {
      max-width: none;
      width: 100%;
    }
    .newsletter-form input,
    .newsletter-cta {
      min-height: 24px;
      font-size: 0.56rem;
      padding-block: 0.3rem;
    }
    .footer-links {
      gap: 0.35rem;
      font-size: 0.55rem;
    }
    .footer-links { text-align: left; }
  }
</style>
