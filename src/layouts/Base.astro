---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  current?: "collaboration" | "studio" | "index" | "contact" | "about" | "home";
  lang?: "en" | "fr";
}
const {
  title = "Ateliers Anouar",
  description = "Bridges between Moroccan artisans and international design.",
  current,
  lang = "en",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/images/logo-black.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Goudy+Bookletter+1911&display=swap" />
  </head>
  <body>
    <Header current={current} lang={lang} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
