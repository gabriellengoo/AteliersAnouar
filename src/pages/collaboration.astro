---
import Base from "../layouts/Base.astro";
import { getLang, strings } from "../i18n/strings";
import handsMark from "../../public/images/hands-mark.png";

const lang = getLang(Astro.url.pathname);
const t = strings[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const localePrefix = lang === "fr" ? "/fr" : "";

const craftIcons = import.meta.glob<{ default: ImageMetadata }>("../../public/images/craft-*.png", { eager: true });
function craft(slug: string) {
  const found = Object.entries(craftIcons).find(([k]) => k.includes(`/${slug}.png`));
  return found?.[1].default;
}
---

<Base current="collaboration" title={`${t.collaboration.title} — Ateliers Anouar`} lang={lang}>
  <section class="container intro">
    <h1 class="page-title">
      <img src={handsMark.src} alt="" />
      {t.collaboration.title}
    </h1>
    <div class="intro-body">
      {t.collaboration.intro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="container services">
    <ul>
      {t.collaboration.services.map((service) => (
        <li class="service">
          <div class="service-title">{service.title}</div>
          <p class="service-body">{service.body}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="container crafts">
    <ol class="crafts-grid">
      {t.collaboration.crafts.map((c, i) => {
        const img = craft(c.icon);
        return (
          <li class="craft">
            {img && <img src={img.src} alt="" />}
            <span class="craft-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="craft-name">{c.name}</span>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="container next-section">
    <a href={`${base}${localePrefix}/studio`} class="next-link">{t.collaboration.next}</a>
  </section>
</Base>

<style>
  .intro {
    width: fit-content;
    grid-template-columns: max-content minmax(0, 760px);
    gap: 1rem;
    max-width: 1360px;
    padding-inline: 0;
    padding-block: 6rem 5rem;
    align-items: start;
  }
  .page-title {
    font-size: clamp(2.5rem, 3.6vw, 3.5rem);
    border-right: 1px solid var(--color-ink);
    padding-right: 1rem;
  }
  .intro-body {
    font-size: 1rem;
    max-width: 78ch;
  }
  .services {
    max-width: 860px;
    padding-block: 3rem;
  }
  .services ul {
    border-top: 1px solid var(--color-rule);
  }
  .service {
    display: grid;
    grid-template-columns: minmax(220px, 320px) minmax(0, 380px);
    gap: 2.5rem;
    padding-block: 1.2rem;
    border-bottom: 1px solid var(--color-rule);
    align-items: start;
  }
  .service-title {
    font-weight: 700;
    font-size: 1.05rem;
  }
  .service-body {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: var(--lh-relaxed);
    max-width: 42ch;
  }

  .crafts {
    max-width: 1080px;
    padding-block: 4.5rem 3rem;
  }
  .crafts-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2.25rem 1rem;
    justify-items: center;
    text-align: center;
  }
  .craft {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    max-width: 190px;
    grid-column: span 4;
  }
  .craft:nth-child(n + 4):nth-child(-n + 7) {
    grid-column: span 3;
  }
  .craft img {
    width: 130px;
    height: 130px;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }
  .craft-num {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    color: var(--color-coral);
  }
  .craft-name {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .next-section {
    display: flex;
    justify-content: flex-end;
    padding-block: var(--space-6);
  }
  .next-link {
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 1.9375rem);
    letter-spacing: var(--letter-tight);
  }
  .next-link:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .intro {
      width: 100%;
      grid-template-columns: 1fr;
      padding-inline: var(--gutter);
      padding-block: 1rem;
      gap: 0.65rem;
    }
    .page-title { font-size: 1.1rem; }
    .page-title {
      border-right: 0;
      padding-right: 0;
    }
    .intro-body { font-size: 0.6rem; }
    .services { padding-block: 0.5rem 1rem; }
    .service {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding-block: 0.5rem;
    }
    .service-title { font-size: 0.58rem; }
    .service-body { font-size: 0.58rem; }
    .crafts {
      max-width: none;
      padding: 1.5rem 0;
    }
    .crafts-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      width: 100%;
    }
    .craft,
    .craft:nth-child(n + 4):nth-child(-n + 7) {
      grid-column: auto;
      width: 100%;
      max-width: none;
    }
    .craft img {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      object-fit: contain;
      margin-bottom: 0;
    }
    .craft-num, .craft-name { font-size: 0.55rem; }
    .next-section { padding-block: 0.75rem; }
    .next-link { font-size: 0.8rem; }
  }
</style>
