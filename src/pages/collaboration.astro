---
import Base from "../layouts/Base.astro";
import { strings } from "../i18n/strings";
import handsMark from "../../public/images/hands-mark.png";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const craftIcons = import.meta.glob<{ default: ImageMetadata }>("../../public/images/craft-*.png", { eager: true });
function craft(slug: string) {
  const found = Object.entries(craftIcons).find(([k]) => k.includes(`/${slug}.png`));
  return found?.[1].default;
}
---

<Base current="collaboration" title="Collaboration — Ateliers Anouar">
  <section class="container intro">
    <h1 class="page-title">
      <img src={handsMark.src} alt="" />
      {t.collaboration.title}
    </h1>
    <div class="intro-body">
      {t.collaboration.intro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="container services">
    <ul>
      {t.collaboration.services.map((service) => (
        <li class="service">
          <div class="service-title">{service.title}</div>
          <p class="service-body">{service.body}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="container crafts">
    <ol class="crafts-grid">
      {t.collaboration.crafts.map((c, i) => {
        const img = craft(c.icon);
        return (
          <li class="craft">
            {img && <img src={img.src} alt="" />}
            <span class="craft-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="craft-name">{c.name}</span>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="container next-section">
    <a href={`${base}/studio`} class="next-link">{t.collaboration.next}</a>
  </section>
</Base>

<style>
  .services {
    padding-block: var(--space-6);
  }
  .services ul {
    border-top: 1px solid var(--color-rule);
  }
  .service {
    display: grid;
    grid-template-columns: minmax(180px, 280px) 1fr;
    gap: var(--space-5);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-rule);
    align-items: start;
  }
  .service-title {
    font-weight: 700;
    font-size: var(--fs-body);
  }
  .service-body {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    max-width: 60ch;
  }

  .crafts {
    padding-block: var(--space-9);
  }
  .crafts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-7) var(--space-5);
    justify-items: center;
    text-align: center;
  }
  .craft {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    max-width: 160px;
  }
  .craft img {
    width: 110px;
    height: 110px;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }
  .craft-num {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--color-ink-soft);
  }
  .craft-name {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
  }

  .next-section {
    display: flex;
    justify-content: flex-end;
    padding-block: var(--space-6);
  }
  .next-link {
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 1.9375rem);
    letter-spacing: var(--letter-tight);
  }
  .next-link:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .service {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    .crafts-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5) var(--space-3);
    }
    .craft img { width: 84px; height: 84px; }
  }
</style>
