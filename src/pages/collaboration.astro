---
import Base from "../layouts/Base.astro";
import { strings } from "../i18n/strings";
import handsMark from "../../public/images/hands-mark.png";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const craftIcons = import.meta.glob<{ default: ImageMetadata }>("../../public/images/craft-*.png", { eager: true });
function craft(slug: string) {
  const found = Object.entries(craftIcons).find(([k]) => k.includes(`/${slug}.png`));
  return found?.[1].default;
}
---

<Base current="collaboration" title="Collaboration — Ateliers Anouar">
  <section class="container intro">
    <h1 class="page-title">
      <img src={handsMark.src} alt="" />
      {t.collaboration.title}
    </h1>
    <div class="intro-body">
      {t.collaboration.intro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="container services">
    <ul>
      {t.collaboration.services.map((service) => (
        <li class="service">
          <div class="service-title">{service.title}</div>
          <p class="service-body">{service.body}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="container crafts">
    <ol class="crafts-grid">
      {t.collaboration.crafts.map((c, i) => {
        const img = craft(c.icon);
        return (
          <li class="craft">
            {img && <img src={img.src} alt="" />}
            <span class="craft-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="craft-name">{c.name}</span>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="container next-section">
    <a href={`${base}/studio`} class="next-link">{t.collaboration.next}</a>
  </section>
</Base>

<style>
  .intro {
    grid-template-columns: minmax(0, 300px) minmax(0, 600px);
    max-width: 1080px;
    padding-block: 2.75rem 2rem;
  }
  .page-title {
    font-size: clamp(1.8rem, 2.6vw, 2.4rem);
  }
  .intro-body {
    font-size: 0.9rem;
    max-width: 64ch;
  }
  .services {
    max-width: 900px;
    padding-block: 2rem;
  }
  .services ul {
    border-top: 1px solid var(--color-rule);
  }
  .service {
    display: grid;
    grid-template-columns: minmax(180px, 280px) 1fr;
    gap: var(--space-5);
    padding-block: 0.85rem;
    border-bottom: 1px solid var(--color-rule);
    align-items: start;
  }
  .service-title {
    font-weight: 700;
    font-size: 0.86rem;
  }
  .service-body {
    font-family: var(--font-serif);
    font-size: 0.86rem;
    line-height: var(--lh-relaxed);
    max-width: 60ch;
  }

  .crafts {
    max-width: 900px;
    padding-block: 4.5rem 3rem;
  }
  .crafts-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2.25rem 1rem;
    justify-items: center;
    text-align: center;
  }
  .craft {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    max-width: 145px;
    grid-column: span 4;
  }
  .craft:nth-child(n + 4):nth-child(-n + 7) {
    grid-column: span 3;
  }
  .craft img {
    width: 100px;
    height: 100px;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }
  .craft-num {
    font-family: var(--font-serif);
    font-size: 0.72rem;
    color: var(--color-coral);
  }
  .craft-name {
    font-family: var(--font-serif);
    font-size: 0.72rem;
  }

  .next-section {
    display: flex;
    justify-content: flex-end;
    padding-block: var(--space-6);
  }
  .next-link {
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 1.9375rem);
    letter-spacing: var(--letter-tight);
  }
  .next-link:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .intro {
      grid-template-columns: 1fr;
      padding-block: 1rem;
      gap: 0.65rem;
    }
    .page-title { font-size: 1.1rem; }
    .intro-body { font-size: 0.6rem; }
    .services { padding-block: 0.5rem 1rem; }
    .service {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding-block: 0.5rem;
    }
    .service-title { font-size: 0.58rem; }
    .service-body { font-size: 0.58rem; }
    .crafts { padding-block: 1.5rem; }
    .crafts-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .craft,
    .craft:nth-child(n + 4):nth-child(-n + 7) {
      grid-column: auto;
      max-width: 120px;
    }
    .craft img { width: 78px; height: 78px; }
    .craft-num, .craft-name { font-size: 0.55rem; }
    .next-section { padding-block: 0.75rem; }
    .next-link { font-size: 0.8rem; }
  }
</style>
