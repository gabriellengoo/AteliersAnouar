---
import HomePage from "../index.astro";
import AboutPage from "../about.astro";
import CollaborationPage from "../collaboration.astro";
import ContactPage from "../contact.astro";
import StudioPage from "../studio.astro";
import ProjectsPage from "../projects/index.astro";
import ProjectPage from "../projects/[slug].astro";
import { strings } from "../../i18n/strings";
import "../../styles/global.css";

export function getStaticPaths() {
  const pages = [
    { path: undefined, page: "home" },
    { path: "about", page: "about" },
    { path: "collaboration", page: "collaboration" },
    { path: "contact", page: "contact" },
    { path: "studio", page: "studio" },
    { path: "projects", page: "projects" },
  ];

  return [
    ...pages.map(({ path, page }) => ({ params: { path }, props: { page } })),
    ...strings.en.index.items.map((item) => ({
      params: { path: `projects/${item.slug}` },
      props: { page: "project", item },
    })),
  ];
}

const { page, item } = Astro.props;
---

{page === "home" && <HomePage />}
{page === "about" && <AboutPage />}
{page === "collaboration" && <CollaborationPage />}
{page === "contact" && <ContactPage />}
{page === "studio" && <StudioPage />}
{page === "projects" && <ProjectsPage />}
{page === "project" && <ProjectPage item={item} />}
