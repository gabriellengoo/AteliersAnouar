---
import Base from "../layouts/Base.astro";
import { strings } from "../i18n/strings";
import logoBlack from "../../public/images/logo-black.png";
import collabPiece from "../../public/images/hero-illustration.png";
import studioPiece from "../../public/images/studio-seat.jpg";
import handsMark from "../../public/images/hands-mark.png";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base current="home">
  <section class="hero">
    <div class="container hero-inner">
      <img src={logoBlack.src} alt="" class="hero-logo" />
    </div>
  </section>

  <div class="canvas">
    <section class="intro-section">
      <div class="intro">
        <h1 class="tagline">
          {t.home.tagline.map((word, i) => (
            <span class:list={["tagline-line", i === t.home.tagline.length - 1 && "has-mark"]}>
              {i === t.home.tagline.length - 1 && (
                <img src={handsMark.src} alt="" class="tagline-mark" aria-hidden="true" />
              )}
              <span class="tagline-word">{word}</span>
            </span>
          ))}
        </h1>
        <p class="intro-body">{t.home.lede}</p>
      </div>
    </section>

    <section class="container featured">
      <a href={`${base}/collaboration`} class="feature-card">
        <div class="feature-image feature-image-illo">
          <img src={collabPiece.src} alt="" />
        </div>
        <span class="feature-cta">{t.home.collabCta}</span>
      </a>
      <a href={`${base}/studio`} class="feature-card">
        <div class="feature-image">
          <img src={studioPiece.src} alt="" />
        </div>
        <span class="feature-cta">{t.home.studioCta}</span>
      </a>
    </section>
  </div>
</Base>

<style>
  .hero {
    background: var(--color-cream);
    padding-block: var(--space-9);
  }
  .hero-inner {
    display: flex;
    justify-content: center;
  }
  .hero-logo {
    width: clamp(180px, 22vw, 280px);
    height: auto;
  }

  .canvas {
    background: var(--color-white);
    flex: 1;
    padding-bottom: var(--space-8);
  }

  .intro-section {
    padding-inline: var(--gutter);
    padding-block: var(--space-8);
  }
  .intro {
    display: grid;
    grid-template-columns: minmax(0, 280px) minmax(0, 720px);
    column-gap: var(--space-7);
    align-items: stretch;
    width: fit-content;
    margin-inline: auto;
  }
  .intro-body {
    border-left: 1px solid var(--color-rule);
    padding-left: var(--space-7);
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    line-height: 1.3;
    padding-top: 0.4em;
  }
  .tagline {
    display: flex;
    flex-direction: column;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.0625rem);
    line-height: 1.15;
    letter-spacing: var(--letter-tight);
    margin: 0;
  }
  .tagline-line {
    position: relative;
    display: block;
  }
  .tagline-mark {
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    width: 0.85em;
    height: 0.85em;
    margin-right: 0.25em;
  }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    padding-block: var(--space-7);
  }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .feature-image {
    aspect-ratio: 4 / 3;
    background: var(--color-white);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feature-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .feature-image-illo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }
  .feature-cta {
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-3);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    letter-spacing: var(--letter-wide);
    text-transform: uppercase;
  }
  .feature-card:hover .feature-cta {
    color: var(--color-ink-soft);
  }

  @media (max-width: 768px) {
    .intro-section { padding-block: var(--space-6); }
    .intro {
      grid-template-columns: 1fr;
      row-gap: var(--space-4);
      max-width: none;
    }
    .intro-body {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--color-rule);
      padding-top: var(--space-4);
      padding-left: 1.2em;
    }
    .tagline { padding-left: 1.2em; }
    .featured {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
