---
import Base from "../layouts/Base.astro";
import { strings } from "../i18n/strings";
import logoBlack from "../../public/images/logo-black.png";
import collabPiece from "../../public/images/hero-illustration.png";
import studioPiece from "../../public/images/studio-seat.jpg";
import handsMark from "../../public/images/hands-mark.png";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base current="home">
  <section class="hero">
    <div class="container hero-inner">
      <img src={logoBlack.src} alt="" class="hero-logo" />
    </div>
  </section>

  <section class="container intro">
    <h1 class="tagline">
      {t.home.tagline.map((word, i) => (
        <span class="tagline-line">
          {i === t.home.tagline.length - 1 && (
            <img src={handsMark.src} alt="" class="tagline-mark" aria-hidden="true" />
          )}
          {word}
        </span>
      ))}
    </h1>
    <p class="intro-body">{t.home.lede}</p>
  </section>

  <section class="container featured">
    <a href={`${base}/collaboration`} class="feature-card">
      <div class="feature-image feature-image-illo">
        <img src={collabPiece.src} alt="" />
      </div>
      <span class="feature-cta">{t.home.collabCta}</span>
    </a>
    <a href={`${base}/studio`} class="feature-card">
      <div class="feature-image">
        <img src={studioPiece.src} alt="" />
      </div>
      <span class="feature-cta">{t.home.studioCta}</span>
    </a>
  </section>
</Base>

<style>
  .hero {
    background: var(--color-cream);
    padding-block: var(--space-9);
    border-bottom: 1px solid var(--color-rule);
  }
  .hero-inner {
    display: flex;
    justify-content: center;
  }
  .hero-logo {
    width: clamp(180px, 22vw, 280px);
    height: auto;
  }

  .intro {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-8);
  }
  .tagline {
    display: flex;
    flex-direction: column;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.0625rem);
    line-height: var(--lh-tight);
    letter-spacing: var(--letter-tight);
    margin: 0;
  }
  .tagline-line {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tagline-mark { width: 0.9em; height: 0.9em; }
  .intro-body {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    line-height: 1.3;
    max-width: 30ch;
    padding-top: 0.5em;
  }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    padding-block: var(--space-7);
  }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .feature-image {
    aspect-ratio: 4 / 3;
    background: var(--color-white);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feature-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .feature-image-illo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }
  .feature-cta {
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-3);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    letter-spacing: var(--letter-wide);
    text-transform: uppercase;
  }
  .feature-card:hover .feature-cta {
    color: var(--color-ink-soft);
  }

  @media (max-width: 768px) {
    .intro {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .featured {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
