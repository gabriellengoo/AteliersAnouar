---
import Base from "../layouts/Base.astro";
import { getLang, strings } from "../i18n/strings";
import logoBlack from "../../public/images/logo-black.png";
import collabPiece from "../../public/images/hero-illustration.png";
import studioPiece from "../../public/images/studio-seat.jpg";
import handsMark from "../../public/images/hands-mark.png";

const lang = getLang(Astro.url.pathname);
const t = strings[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const localePrefix = lang === "fr" ? "/fr" : "";
const link = (path: string) => `${base}${localePrefix}${path}`;
---

<Base current="home" lang={lang}>
  <section class="hero">
    <div class="container hero-inner">
      <img src={logoBlack.src} alt="" class="hero-logo" />
    </div>
  </section>

  <div class="canvas">
    <section class="intro-section">
      <div class="intro">
        <h1 class="tagline">
          {t.home.tagline.map((word, i) => (
            <span class:list={["tagline-line", i === t.home.tagline.length - 1 && "has-mark"]}>
              {i === t.home.tagline.length - 1 && (
                <img src={handsMark.src} alt="" class="tagline-mark" aria-hidden="true" />
              )}
              <span class="tagline-word">{word}</span>
            </span>
          ))}
        </h1>
        <p class="intro-body">{t.home.lede}</p>
      </div>
    </section>

    <section class="container featured">
      <a href={link("/collaboration")} class="feature-card">
        <div class="feature-image feature-image-illo">
          <img src={collabPiece.src} alt="" />
        </div>
        <span class="feature-cta">{t.home.collabCta}</span>
      </a>
      <a href={link("/studio")} class="feature-card">
        <div class="feature-image">
          <img src={studioPiece.src} alt="" />
        </div>
        <span class="feature-cta">{t.home.studioCta}</span>
      </a>
    </section>
  </div>
</Base>

<style>
  .hero {
    background: var(--color-cream);
    padding-block: 4.5rem;
  }
  .hero-inner {
    display: flex;
    justify-content: center;
  }
  .hero-logo {
    width: clamp(130px, 14vw, 190px);
    height: auto;
  }

  .canvas {
    background: var(--color-white);
    flex: 1;
    padding-bottom: var(--space-8);
  }

  .intro-section {
    padding-inline: var(--gutter);
    padding-block: 3.25rem 2.75rem;
  }
  .intro {
    display: grid;
    grid-template-columns: minmax(0, 210px) minmax(0, 430px);
    column-gap: 2.25rem;
    align-items: stretch;
    width: fit-content;
    margin-inline: auto;
  }
  .intro-body {
    border-left: 1px solid var(--color-rule);
    padding-left: 2.25rem;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.45vw, 1.25rem);
    line-height: 1.4;
    padding-top: 0.4em;
  }
  .tagline {
    display: flex;
    flex-direction: column;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.7rem, 2.4vw, 2.25rem);
    line-height: 1.08;
    letter-spacing: var(--letter-tight);
    margin: 0;
  }
  .tagline-line {
    position: relative;
    display: block;
  }
  .tagline-mark {
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    width: 0.85em;
    height: 0.85em;
    margin-right: 0.25em;
  }

  .featured {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 300px));
    justify-content: center;
    gap: 1.5rem;
    padding-block: 2rem var(--space-7);
  }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .feature-image {
    aspect-ratio: 3 / 4;
    background: var(--color-white);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feature-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .feature-image-illo img {
    width: 76%;
    height: 76%;
    object-fit: contain;
  }
  .feature-cta {
    border-top: 1px solid var(--color-black);
    padding-top: var(--space-3);
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    letter-spacing: var(--letter-wide);
    text-transform: uppercase;
  }
  .feature-card:hover .feature-cta {
    color: var(--color-ink-soft);
  }
  .feature-card:hover .feature-image img {
    opacity: 0.58;
  }

  @media (max-width: 768px) {
    .hero {
      height: calc(100svh - 43px);
      min-height: 460px;
      padding: 0;
      background: var(--color-cream);
    }
    .hero-inner {
      height: 100%;
      max-width: none;
      padding: 0;
      align-items: center;
    }
    .hero-logo {
      width: 40%;
      height: 40%;
      object-fit: contain;
    }
    .intro-section {
      padding-inline: var(--gutter);
      padding-block: 1.25rem 1.5rem;
      background: var(--color-white);
    }
    .intro {
      grid-template-columns: 1fr;
      row-gap: 0.65rem;
      max-width: none;
      width: 100%;
    }
    .intro-body {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--color-rule);
      padding-top: 0.65rem;
      font-size: 0.68rem;
      max-width: none;
      width: 100%;
    }
    .tagline {
      padding-left: 1.1em;
      font-size: 1.35rem;
      width: 100%;
    }
    .featured {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0 0 1.25rem;
      background: var(--color-white);
    }
    .feature-card {
      gap: 0.4rem;
    }
    .feature-image {
      width: 100%;
      aspect-ratio: 2 / 3;
    }
    .feature-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .feature-image-illo {
      aspect-ratio: 2 / 3;
    }
    .feature-image-illo img {
      width: 82%;
      height: 82%;
      object-fit: contain;
    }
    .feature-cta {
      margin-inline: var(--gutter);
      padding-top: 0.35rem;
      font-size: 0.55rem;
    }
    .canvas { padding-bottom: 0; }
  }
</style>
