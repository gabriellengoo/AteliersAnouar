---
import Base from "../../layouts/Base.astro";
import { getLang, strings } from "../../i18n/strings";
import handsMark from "../../../public/images/hands-mark.png";
import projectHero from "../../../public/images/studio-lantern.jpg";

const lang = getLang(Astro.url.pathname);
const t = strings[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const localePrefix = lang === "fr" ? "/fr" : "";

export function getStaticPaths() {
  return strings.en.index.items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const localizedItem = t.index.items.find((entry) => entry.slug === item?.slug) ?? item;
const heading = localizedItem?.name ?? t.index.items[0].name;
---

<Base current="index" title={`${heading} — Ateliers Anouar`} lang={lang}>
  <section class="container project-head">
    <h1 class="project-title">
      <img src={handsMark.src} alt="" />
      {heading}
    </h1>
    <p class="project-meta serif">{localizedItem?.place} | {localizedItem?.date}</p>
    <a href={`${base}${localePrefix}/projects`} class="back-link">{t.project.back}</a>
  </section>

  <section class="container project-hero">
    <figure>
      <img src={projectHero.src} alt={heading} />
      <div class="mobile-project-placeholder" aria-hidden="true"></div>
      <figcaption class="caption">
        <strong>Image title</strong><br />
        <span class="serif">{t.project.caption}</span>
      </figcaption>
    </figure>
  </section>

  <section class="container project-text">
    <div class="text-block">
      <p class="eyebrow">{t.project.placeholderHeading}</p>
      <p class="serif body">{t.project.placeholderBody}</p>
    </div>
    <div class="text-block">
      <p class="eyebrow">{t.project.placeholderHeading}</p>
      <p class="serif body">{t.project.placeholderBody}</p>
    </div>
  </section>

  <section class="container project-grid two-col">
    <figure><div class="placeholder"></div><figcaption class="caption">Image title<br /><span class="serif">{t.project.caption}</span></figcaption></figure>
    <figure><div class="placeholder"></div><figcaption class="caption">Image title<br /><span class="serif">{t.project.caption}</span></figcaption></figure>
  </section>

  <section class="container project-grid three-col">
    <figure><div class="placeholder tall"></div></figure>
    <figure><div class="placeholder tall"></div></figure>
    <figure><div class="placeholder tall"></div></figure>
  </section>
</Base>

<style>
  :global(main) { background: var(--color-white); }
  .project-head {
    display: grid;
    grid-template-columns: max-content auto;
    align-items: center;
    width: 100%;
    max-width: 1080px;
    padding-inline: var(--gutter);
    padding-block: 4rem 3rem;
    gap: 1rem;
  }
  .project-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    letter-spacing: var(--letter-tight);
  }
  .project-title {
    border-right: 1px solid var(--color-ink);
    padding-right: 1rem;
  }
  .project-title img { width: 1em; height: 1em; }
  .back-link {
    display: block;
    position: fixed;
    right: var(--gutter);
    bottom: var(--space-5);
    z-index: 20;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-ink);
    background: var(--color-white);
    border: 1px solid var(--color-ink);
    padding: 0.55rem 0.75rem;
  }
  .project-meta {
    display: block;
    font-size: 1rem;
    white-space: nowrap;
  }
  .mobile-project-placeholder { display: none; }
  .back-link:hover { color: var(--color-ink); }

  .project-hero {
    max-width: 1080px;
    padding-block: 2rem 4rem;
  }
  .project-hero img {
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
  }
  .caption {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--color-ink-soft);
    margin-top: var(--space-2);
  }

  .project-text {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    width: 50%;
    max-width: 760px;
    padding: 3rem;
    background: var(--color-cream);
    margin: 0 auto;
  }
  .text-block .eyebrow { margin-bottom: var(--space-2); }
  .text-block .body {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: var(--lh-relaxed);
    max-width: 50ch;
  }

  .project-grid {
    display: grid;
    gap: var(--space-5);
    max-width: 1080px;
    padding-block: 1.5rem;
  }
  .project-grid.two-col { grid-template-columns: 1fr 1fr; }
  .project-grid.three-col { grid-template-columns: repeat(3, 1fr); }

  .placeholder {
    background: var(--color-rule-soft);
    aspect-ratio: 3 / 4;
  }
  .placeholder.tall { aspect-ratio: 2 / 3; }

  @media (max-width: 768px) {
    .project-head {
      display: block;
      width: 100%;
      padding-inline: var(--gutter);
      padding-block: 0.8rem;
      background: var(--color-white);
    }
    .project-title {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
      width: 100%;
      font-size: 1.45rem;
      max-width: 9ch;
      margin-bottom: 0.7rem;
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--color-rule);
      border-right: 0;
      padding-right: 0;
    }
    .project-title img {
      width: 1.25em;
      height: 1.25em;
    }
    .project-meta {
      display: block;
      font-size: 0.55rem;
    }
    .back-link {
      right: var(--gutter);
      bottom: var(--gutter);
      font-size: 0.58rem;
      padding: 0.4rem 0.5rem;
    }
    .project-hero {
      padding-block: 0.75rem;
      background: var(--color-white);
    }
    .project-hero img { display: none; }
    .mobile-project-placeholder {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      background: var(--color-rule-soft);
    }
    .caption { font-size: 0.5rem; }
    .caption strong {
      font-family: var(--font-sans);
      font-size: 0.62rem;
      text-transform: uppercase;
    }
    .project-text, .project-grid.two-col, .project-grid.three-col {
      grid-template-columns: 1fr;
    }
    .project-text {
      width: 100%;
      gap: 1rem;
      padding: 1.25rem var(--gutter);
      background: var(--color-cream);
    }
    .text-block .eyebrow { font-size: 0.55rem; }
    .text-block .body { font-size: 0.55rem; }
    .project-grid {
      gap: 0.75rem;
      padding-block: 0.75rem;
      background: var(--color-white);
    }
    .placeholder,
    .placeholder.tall { aspect-ratio: 4 / 3; }
  }
</style>
