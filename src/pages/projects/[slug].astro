---
import Base from "../../layouts/Base.astro";
import { strings } from "../../i18n/strings";
import handsMark from "../../../public/images/hands-mark.png";
import projectHero from "../../../public/images/studio-lantern.jpg";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

export function getStaticPaths() {
  return strings.en.index.items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const heading = item?.name ?? "Honouring Heritage";
---

<Base current="index" title={`${heading} — Ateliers Anouar`}>
  <section class="container project-head">
    <h1 class="project-title">
      <img src={handsMark.src} alt="" />
      {heading}
    </h1>
    <p class="project-meta serif">{item?.place} | {item?.date}</p>
    <a href={`${base}/projects`} class="back-link">{t.project.back}</a>
  </section>

  <section class="container project-hero">
    <figure>
      <img src={projectHero.src} alt={heading} />
      <div class="mobile-project-placeholder" aria-hidden="true"></div>
      <figcaption class="caption">
        <strong>Image title</strong><br />
        <span class="serif">{t.project.caption}</span>
      </figcaption>
    </figure>
  </section>

  <section class="container project-text">
    <div class="text-block">
      <p class="eyebrow">{t.project.placeholderHeading}</p>
      <p class="serif body">{t.project.placeholderBody}</p>
    </div>
    <div class="text-block">
      <p class="eyebrow">{t.project.placeholderHeading}</p>
      <p class="serif body">{t.project.placeholderBody}</p>
    </div>
  </section>

  <section class="container project-grid two-col">
    <figure><div class="placeholder"></div><figcaption class="caption">Image title<br /><span class="serif">{t.project.caption}</span></figcaption></figure>
    <figure><div class="placeholder"></div><figcaption class="caption">Image title<br /><span class="serif">{t.project.caption}</span></figcaption></figure>
  </section>

  <section class="container project-grid three-col">
    <figure><div class="placeholder tall"></div></figure>
    <figure><div class="placeholder tall"></div></figure>
    <figure><div class="placeholder tall"></div></figure>
  </section>
</Base>

<style>
  .project-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.25rem;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .project-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 1.9375rem);
    letter-spacing: var(--letter-tight);
  }
  .project-title img { width: 1em; height: 1em; }
  .back-link {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--color-ink-soft);
  }
  .project-meta { display: none; }
  .mobile-project-placeholder { display: none; }
  .back-link:hover { color: var(--color-ink); }

  .project-hero {
    max-width: 900px;
    padding-block: 1.5rem;
  }
  .project-hero img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .caption {
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    color: var(--color-ink-soft);
    margin-top: var(--space-2);
  }

  .project-text {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    padding-block: 2rem;
    background: var(--color-white);
    padding-inline: var(--gutter);
    margin-inline: 0;
    max-width: none;
  }
  .text-block .eyebrow { margin-bottom: var(--space-2); }
  .text-block .body {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    max-width: 50ch;
  }

  .project-grid {
    display: grid;
    gap: var(--space-5);
    max-width: 900px;
    padding-block: 1.5rem;
  }
  .project-grid.two-col { grid-template-columns: 1fr 1fr; }
  .project-grid.three-col { grid-template-columns: repeat(3, 1fr); }

  .placeholder {
    background: var(--color-rule-soft);
    aspect-ratio: 4 / 3;
  }
  .placeholder.tall { aspect-ratio: 3 / 4; }

  @media (max-width: 768px) {
    .project-head {
      display: block;
      padding-block: 0.8rem;
      background: var(--color-white);
    }
    .project-title {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
      width: 100%;
      font-size: 1.45rem;
      max-width: 9ch;
      margin-bottom: 0.7rem;
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--color-rule);
    }
    .project-title img {
      width: 1.25em;
      height: 1.25em;
    }
    .project-meta {
      display: block;
      font-size: 0.55rem;
    }
    .back-link { display: none; }
    .project-hero {
      padding-block: 0.75rem;
      background: var(--color-white);
    }
    .project-hero img { display: none; }
    .mobile-project-placeholder {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      background: var(--color-rule-soft);
    }
    .caption { font-size: 0.5rem; }
    .caption strong {
      font-family: var(--font-sans);
      font-size: 0.62rem;
      text-transform: uppercase;
    }
    .project-text, .project-grid.two-col, .project-grid.three-col {
      grid-template-columns: 1fr;
    }
    .project-text {
      gap: 1rem;
      padding: 1.25rem var(--gutter);
      background: var(--color-white);
    }
    .text-block .eyebrow { font-size: 0.55rem; }
    .text-block .body { font-size: 0.55rem; }
    .project-grid {
      gap: 0.75rem;
      padding-block: 0.75rem;
      background: var(--color-white);
    }
    .placeholder,
    .placeholder.tall { aspect-ratio: 4 / 3; }
  }
</style>
