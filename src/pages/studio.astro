---
import Base from "../layouts/Base.astro";
import { strings } from "../i18n/strings";
import handsMark from "../../public/images/hands-mark.png";
import lantern from "../../public/images/studio-lantern.jpg";
import seat from "../../public/images/studio-seat.jpg";

const t = strings.en;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const images: Record<string, ImageMetadata> = {
  "studio-lantern": lantern,
  "studio-seat": seat,
};
---

<Base current="studio" title="Studio — Ateliers Anouar">
  <section class="container intro">
    <h1 class="page-title">
      <img src={handsMark.src} alt="" />
      {t.studio.title}
    </h1>
    <p class="intro-body">{t.studio.intro}</p>
  </section>

  <section class="container pieces">
    {t.studio.pieces.map((piece) => (
      <article class="piece">
        <div class="piece-image">
          {images[piece.image] && <img src={images[piece.image].src} alt={piece.name} />}
        </div>
        <div class="piece-meta">
          <h2 class="piece-name">{piece.name}</h2>
          <p class="piece-body">{piece.body}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="container next-section">
    <a href={`${base}/collaboration`} class="next-link">{t.studio.next}</a>
  </section>
</Base>

<style>
  .pieces {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    padding-block: var(--space-7);
    max-width: 900px;
  }
  .piece {
    display: grid;
    grid-template-columns: minmax(260px, 420px) minmax(0, 1fr);
    gap: var(--space-7);
    align-items: end;
  }
  .piece-image {
    background: var(--color-white);
    aspect-ratio: 2 / 3;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .piece-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .piece-meta {
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-3);
  }
  .piece-name {
    font-size: var(--fs-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--letter-wide);
    margin-bottom: var(--space-2);
  }
  .piece-body {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: var(--lh-relaxed);
    max-width: 38ch;
  }

  .next-section {
    display: flex;
    justify-content: flex-end;
    padding-block: var(--space-6);
  }
  .next-link {
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 1.9375rem);
    letter-spacing: var(--letter-tight);
  }
  .next-link:hover { opacity: 0.6; }

  @media (max-width: 768px) {
    .intro {
      padding-block: 1rem 0.8rem;
      gap: 0.7rem;
      background: var(--color-white);
    }
    .page-title { font-size: 1.45rem; }
    .intro-body {
      font-size: 0.6rem;
      max-width: 42ch;
    }
    .pieces {
      gap: 1.25rem;
      padding: 0 0 1rem;
      max-width: none;
      background: var(--color-white);
    }
    .piece, .piece:nth-child(even) {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .piece:nth-child(even) .piece-meta { order: 0; }
    .piece-image {
      width: 100%;
      aspect-ratio: 2 / 3;
    }
    .piece-image img { object-fit: cover; }
    .piece-meta {
      margin-inline: var(--gutter);
      padding-top: 0.35rem;
    }
    .piece-name {
      font-size: 0.62rem;
      margin-bottom: 0.2rem;
    }
    .piece-body { font-size: 0.58rem; }
    .next-section {
      padding-block: 0.75rem;
      background: var(--color-white);
    }
    .next-link { font-size: 1rem; }
  }
</style>
